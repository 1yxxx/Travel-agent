# =============================================
# TripAI — DeepSeek 版环境变量
# 复制为 .env 并填入你的 Key
# =============================================

# ====== LLM (必填 — 使用 DeepSeek) ======
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7

# ====== 国内 API (真实数据源) ======
# 高德地图 Web API: https://lbs.amap.com
AMAP_API_KEY=
# 聚合数据: https://www.juhe.cn → 航班订票查询 + 火车订票查询
JUHE_FLIGHT_KEY=
JUHE_TRAIN_KEY=
# 和风天气: https://dev.qweather.com → 控制台 → JWT 凭据
QWEATHER_KEY_ID=
QWEATHER_PRIVATE_KEY=

# ====== 可观测性 (可选) ======
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=travel-agent

# ====== 持久化 — 云服务器本地部署 ======
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:your_password@localhost:5432/tripai

# ====== Chroma 本地知识库 (RAG) ======
# 默认使用本地 ChromaDB，数据存储在 chroma_data/ 目录
# 导入: python backend/scripts/ingest_local_knowledge_to_chroma.py
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=travel_local_expert_knowledge
CHROMA_TOP_K=4

# ====== Agent 参数 (可选) ======
RETRY_MAX_ATTEMPTS=3
CACHE_TTL_HOURS=24
MAX_TOOL_CALLS=5
BUDGET_MAX_RETRIES=3
