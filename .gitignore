# 环境变量 (包含敏感信息)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
.venv/
env/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 日志
*.log
logs/

# 缓存
.cache/
*.cache

# 本地数据
data/
*.db
*.sqlite3

# Chroma 向量库
chroma_data/

# Jupyter
.ipynb_checkpoints/

# 临时文件
tmp/
temp/
